#!/usr/bin/env bash
set -euo pipefail

# Self-discovering Claude Code hook — safe no-op outside srcery tmux or non-worktree CWD.

# Must be running inside tmux on the srcery socket
[[ -n "${TMUX:-}" ]] || exit 0
[[ "$TMUX" == *"${SRCERY_TMUX_SOCKET:-srcery}"* ]] || exit 0
[[ -n "${TMUX_PANE:-}" ]] || exit 0

# Derive worktree name from pane CWD
pane_cwd=$(tmux -L "${SRCERY_TMUX_SOCKET:-srcery}" display-message -t "$TMUX_PANE" -p '#{pane_current_path}')
wt_name=$(basename "$pane_cwd")

# Must be a managed worktree
data_dir="${SRCERY_DATA:-${SRCERY_ROOT:?}/data}"
[[ -d "$data_dir/worktrees/$wt_name" ]] || exit 0

# Status file keyed by pane ID (e.g. %0, %1)
status_file="$data_dir/status/$wt_name/$TMUX_PANE"

input=$(cat)

# Simple JSON string extraction (no jq dependency)
json_str() {
	grep -o "\"$1\"[[:space:]]*:[[:space:]]*\"[^\"]*\"" <<< "$input" \
		| head -1 | cut -d'"' -f4 || true
}

event=$(json_str hook_event_name)
message=$(json_str message)

case "$event" in
	Notification)
		notification_type=$(json_str notification_type)
		case "$notification_type" in
			idle_prompt)       status="idle" ;;
			permission_prompt) status="attention" ;;
			*)                 exit 0 ;;
		esac
		mkdir -p "$(dirname "$status_file")"
		echo "$status" > "$status_file"

		# macOS notification if available, else terminal bell
		if command -v osascript &>/dev/null; then
			osascript -e "display notification \"${message:-Claude needs attention}\" with title \"srcery\"" &>/dev/null || true
		else
			printf '\a' > /dev/tty 2>/dev/null || true
		fi
		;;
	UserPromptSubmit)
		rm -f "$status_file"
		;;
esac
