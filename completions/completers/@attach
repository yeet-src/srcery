#!/usr/bin/env bash
# Completer for @attach: POS WORD...
pos=${1:-0}; shift 2>/dev/null || true
case $pos in
    1)
        windows=$(tmux -L "${SRCERY_TMUX_SOCKET:-srcery}" list-windows -t '=srcery' -F '#{window_name}' 2>/dev/null | grep -v '^_placeholder$')
        [[ -z "$windows" ]] && exit 0
        # worktree names (unique prefixes before /)
        echo "$windows" | sed 's|/.*||' | sort -u
        # @<name> service names (unique suffixes after /)
        echo "$windows" | sed 's|.*/|@|' | sort -u
        ;;
esac
