#!/usr/bin/env bash
# Completer for @attach: POS WORD...
pos=${1:-0}; shift 2>/dev/null || true
case $pos in
    1)
        windows=$(tmux -L "${SRCERY_TMUX_SOCKET:-srcery}" list-windows -t '=srcery' -F '#{window_name} #{pane_current_path}' 2>/dev/null | grep -v '^_placeholder ')
        [[ -z "$windows" ]] && exit 0
        # worktree names (unique basenames of CWD)
        echo "$windows" | awk '{print $2}' | xargs -n1 basename | sort -u
        # @<name> service names (unique window names)
        echo "$windows" | awk '{print "@"$1}' | sort -u
        ;;
esac
