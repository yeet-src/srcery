#!/usr/bin/env srcery-bash

cat <<'EOF'
Workflow
  @dev REPO [BRANCH [BASE]]    Create worktree, start claude, attach

Worktrees
  @wt-create REPO [BRANCH [BASE]]  Create a worktree for REPO, setup & run
  @wt-list [REPO]       List worktrees, optionally filtered by REPO
  @wt-remove NAME       Remove a worktree (kills its tmux windows)
  @wt-clear             Remove all worktrees (with confirmation)
  @ps [FILTER]          Detailed pane view (full commands, grouped by worktree)

Sessions
  @shell WT_NAME           Start a shell in a worktree + attach
  @attach                  Attach to all windows
  @attach <wt>             Attach to one worktree's windows
  @attach @<name>          Attach to all windows with a given name
  (underlying: tmux -L srcery attach-session -t '=srcery[/filter]')

Setup
  @install-hooks           Merge srcery notification hooks into ~/.claude/settings.json
EOF
