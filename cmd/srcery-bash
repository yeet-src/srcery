#!/usr/bin/env bash
export PATH="$PATH:$SRCERY_ROOT/lib"
cd "$SRCERY_ROOT" || exit 1

export SRCERY_DATA="${SRCERY_DATA:-$SRCERY_ROOT/data}"

die() {
	>&2 echo "$@"
	exit 1
}
export -f die

export SRCERY_TMUX_SOCKET="${SRCERY_TMUX_SOCKET:-srcery}"

srcery_tmux() {
	command tmux -L "$SRCERY_TMUX_SOCKET" "$@"
}
export -f srcery_tmux

# srcery_new_window NAME PATH [CMD...]
# Ensures srcery master session exists, creates a detached window, prints window ID.
srcery_new_window() {
	local name="$1" path="$2"
	shift 2
	srcery_tmux has-session -t "=srcery" 2>/dev/null \
		|| srcery_tmux new-session -d -s srcery -n _placeholder 2>/dev/null \
		|| true
	srcery_tmux set-option -gw remain-on-exit on
	local wid
	wid=$(srcery_tmux new-window -d -t "=srcery" -n "$name" -c "$path" -P -F '#{window_id}' "$@")
	srcery_tmux kill-window -t "=srcery:=_placeholder" 2>/dev/null || true
	echo "$wid"
}
export -f srcery_new_window

exec bash -euo pipefail "$@"
