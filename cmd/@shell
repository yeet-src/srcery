#!/usr/bin/env srcery-bash

wt_name="${1:?usage: @shell WT_NAME}"
wt_path="$SRCERY_DATA/worktrees/$wt_name"

[[ -d "$wt_path" ]] || die "worktree not found: $wt_name"

# resolve to absolute (pwd -P to match tmux's pane_current_path)
wt_path=$(cd "$wt_path" && pwd -P)

srcery_new_window shell "$wt_path" >/dev/null

exec @attach "$wt_name"
