#!/usr/bin/env srcery-bash

win="${1:?usage: @svc-stop WINDOW_ID}"

srcery_tmux has-session -t "=srcery" 2>/dev/null \
	|| die "no services running"

# query window info before killing (for status cleanup and display)
info=$(srcery_tmux list-windows -t "=srcery" -F '#{window_id} #{window_name} #{pane_current_path} #{pane_dead} #{pane_pid}' \
	| grep "^${win} ") || die "no such service: $win"
read -r _id wname cwd dead pid <<< "$info"

if [[ "$dead" == "1" ]]; then
	echo "already dead (pid $pid), cleaning up"
else
	echo "stopped $wname (pid $pid)"
fi

srcery_tmux kill-window -t "$win"

# clean up status file
wt_name=$(basename "$cwd")
status_file="$SRCERY_DATA/status/$wt_name/$wname"
rm -f "$status_file"
