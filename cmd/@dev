#!/usr/bin/env srcery-bash

repo="${1:?usage: @dev REPO [BRANCH [BASE]]}"
branch="${2:-}"
base="${3:-}"
: "${CLAUDE_BIN:=claude}"

@install-hooks

wt_path=$(@wt-create "$repo" "$branch" "$base")
wt_name=$(basename "$wt_path")

# resolve to absolute (pwd -P to match tmux's pane_current_path)
wt_path=$(cd "$wt_path" && pwd -P)

srcery_new_window shell "$wt_path" >/dev/null

srcery_new_window claude "$wt_path" \
	"$CLAUDE_BIN" --dangerously-skip-permissions \
	--append-system-prompt 'You are a background worktree agent managed by srcery. Work autonomously — do not ask clarifying questions unless truly stuck. Commit eagerly after completing logical units of work. When finished, leave the worktree in a clean committed state with no uncommitted changes.' >/dev/null

exec @attach "$wt_name"
