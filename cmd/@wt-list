#!/usr/bin/env srcery-bash

[[ -d "$SRCERY_DATA/worktrees" ]] || exit 0

filter="${1:-}"

# collect service windows if tmux server is running
svc_windows=""
if srcery_tmux has-session -t "=srcery" 2>/dev/null; then
	svc_windows=$(srcery_tmux list-windows -t "=srcery" -F '#{window_name} #{pane_current_path} #{pane_dead}')
fi

{
printf "%s\t%s\t%s\t%s\n" NAME REPO BRANCH SERVICES

for wt in "$SRCERY_DATA"/worktrees/*/; do
	[[ -d "$wt" ]] || continue
	name="${wt%/}"
	name="${name##*/}"

	if [[ -f "$wt.git" ]]; then
		gitdir=$(<"$wt.git")
		gitdir="${gitdir#gitdir: }"
		repo_path="${gitdir%/.git/worktrees/*}"
		repo="${repo_path##*/}"
		branch=$(git -C "$wt" branch --show-current 2>/dev/null || echo "-")
	else
		repo="-"
		branch="-"
	fi

	[[ -z "$filter" ]] || [[ "$repo" == "$filter" ]] || continue

	# resolve to absolute for matching (pwd -P to match tmux's pane_current_path)
	abs_wt_path=$(cd "$wt" && pwd -P)

	# gather services for this worktree (matched by CWD)
	svcs=""
	if [[ -n "$svc_windows" ]]; then
		while read -r wname cwd dead; do
			[[ "$cwd" == "$abs_wt_path" || "$cwd" == "$abs_wt_path/"* ]] || continue
			if [[ "$dead" != "0" ]]; then
				svcs="${svcs:+$svcs,}${wname}(dead)"
			elif [[ -f "$SRCERY_DATA/status/$name/$wname" ]]; then
				svc_status=$(<"$SRCERY_DATA/status/$name/$wname")
				svcs="${svcs:+$svcs,}${wname}(${svc_status})"
			else
				svcs="${svcs:+$svcs,}$wname"
			fi
		done <<< "$svc_windows"
	fi

	printf "%s\t%s\t%s\t%s\n" "$name" "$repo" "$branch" "${svcs:--}"
done
} | column -t -s $'\t'
