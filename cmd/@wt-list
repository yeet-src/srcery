#!/usr/bin/env srcery-bash

[[ -d "$SRCERY_DATA/worktrees" ]] || exit 0

filter="${1:-}"

# collect pane info if tmux server is running
pane_info=""
if srcery_tmux has-session -t "=srcery" 2>/dev/null; then
	pane_info=$(srcery_tmux list-panes -s -t "=srcery" -F '#{pane_current_command} #{pane_current_path} #{pane_dead} #{pane_id}')
fi

{
printf "%s\t%s\t%s\t%s\n" NAME REPO BRANCH PANES

for wt in "$SRCERY_DATA"/worktrees/*/; do
	[[ -d "$wt" ]] || continue
	name="${wt%/}"
	name="${name##*/}"

	if [[ -f "$wt.git" ]]; then
		gitdir=$(<"$wt.git")
		gitdir="${gitdir#gitdir: }"
		repo_path="${gitdir%/.git/worktrees/*}"
		repo="${repo_path##*/}"
		branch=$(git -C "$wt" branch --show-current 2>/dev/null || echo "-")
	else
		repo="-"
		branch="-"
	fi

	[[ -z "$filter" ]] || [[ "$repo" == "$filter" ]] || continue

	# resolve to absolute for matching (pwd -P to match tmux's pane_current_path)
	abs_wt_path=$(cd "$wt" && pwd -P)

	# gather panes for this worktree (matched by CWD)
	panes=""
	if [[ -n "$pane_info" ]]; then
		while read -r pcmd cwd dead pane_id; do
			[[ "$cwd" == "$abs_wt_path" || "$cwd" == "$abs_wt_path/"* ]] || continue
			if [[ "$dead" != "0" ]]; then
				panes="${panes:+$panes,}${pcmd}(dead)"
			elif [[ -f "$SRCERY_DATA/status/$name/$pane_id" ]]; then
				pane_status=$(<"$SRCERY_DATA/status/$name/$pane_id")
				panes="${panes:+$panes,}${pcmd}(${pane_status})"
			else
				panes="${panes:+$panes,}$pcmd"
			fi
		done <<< "$pane_info"
	fi

	printf "%s\t%s\t%s\t%s\n" "$name" "$repo" "$branch" "${panes:--}"
done
} | column -t -s $'\t'
